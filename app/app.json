{
  "expo": {
    "name": "Shelf",
    "slug": "shelf",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "shelf",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shelf.app",
      "infoPlist": {
        "AppGroup": "group.com.shelf.app",
        "AppGroupIdentifier": "group.com.shelf.app"
      },
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.shelf.app"]
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-sqlite",
      "expo-web-browser",
      [
        "expo-share-extension",
        {
          "activationRules": [{ "type": "url", "max": 1 }],
          "height": 380
        }
      ]
    ]
  }
}
